# ══════════════════════════════════════════════
#         GROKS HOTEL — ENVIRONMENT VARIABLES
# ══════════════════════════════════════════════
# Copy this file, rename it to .env
# Then fill in YOUR own values below


# ── SERVER ─────────────────────────────────────
PORT=5000


# ── MONGODB ────────────────────────────────────
# Get from mongodb.com/atlas (free cluster)
# Replace YOUR_USERNAME, YOUR_PASSWORD, and the cluster address
MONGO_URI=mongodb+srv://YOUR_USERNAME:YOUR_PASSWORD@cluster0.xxxxx.mongodb.net/groks-hotel?retryWrites=true&w=majority


# ── JWT ────────────────────────────────────────
# Any long random text — keep it secret
JWT_SECRET=groks-hotel-super-secret-key-change-this-to-something-random
JWT_EXPIRE=30d
COOKIE_EXPIRE=30


# ── EMAIL ──────────────────────────────────────
# Use your Gmail. EMAIL_PASS is a Gmail App Password (not your normal password)
# Get it at: myaccount.google.com → Security → App Passwords
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_USER=youremail@gmail.com
EMAIL_PASS=your-16-character-app-password


# ── PAYSTACK ───────────────────────────────────
# Get from dashboard.paystack.com → Settings → API Keys
# Use sk_test_ and pk_test_ while testing
PAYSTACK_SECRET_KEY=sk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
PAYSTACK_PUBLIC_KEY=pk_test_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx


# ── FRONTEND URL ───────────────────────────────
# Keep this while developing locally
# Change to your frontend production URL when you deploy
CLIENT_URL=http://localhost:5173